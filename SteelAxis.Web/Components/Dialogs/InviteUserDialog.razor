@using SteelAxis.Shared.DTOs
@using SteelAxis.Web.Services
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Invite New User</MudText>

        <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model.Email"
                          Label="Email Address"
                          Variant="Variant.Outlined"
                          Required="true"
                          InputType="InputType.Email"
                          For="@(() => _model.Email)"
                          Class="mb-4" />

            <MudTextField @bind-Value="_model.FirstName"
                          Label="First Name"
                          Variant="Variant.Outlined"
                          For="@(() => _model.FirstName)"
                          Class="mb-4" />

            <MudTextField @bind-Value="_model.LastName"
                          Label="Last Name"
                          Variant="Variant.Outlined"
                          For="@(() => _model.LastName)"
                          Class="mb-4" />

            <MudSelect @bind-Value="_model.Role"
                       Label="Role"
                       Variant="Variant.Outlined"
                       Required="true"
                       For="@(() => _model.Role)"
                       Class="mb-4">
                <MudSelectItem Value="@("User")">User - Basic access</MudSelectItem>
                <MudSelectItem Value="@("Manager")">Manager - Can manage users</MudSelectItem>
                <MudSelectItem Value="@("Admin")">Admin - Full access</MudSelectItem>
            </MudSelect>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
            }
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="HandleSubmit" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   Disabled="_loading">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Send Invitation
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private dynamic MudDialog { get; set; } = null!;

    [Inject]
    private IUserHttpService UserService { get; set; } = null!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = null!;

    private InviteModel _model = new() { Role = "User" };
    private bool _loading = false;
    private string? _errorMessage;

    // Mutable model for two-way binding
    private class InviteModel
    {
        public string Email { get; set; } = string.Empty;
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string Role { get; set; } = "User";
    }

    private async Task HandleSubmit()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            var request = new InviteUserRequest
            {
                Email = _model.Email,
                FirstName = _model.FirstName,
                LastName = _model.LastName,
                Role = _model.Role
            };

            var result = await UserService.InviteUserAsync(request);

            if (result != null)
            {
                Snackbar.Add($"Invitation sent to {_model.Email}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(result));
            }
            else
            {
                _errorMessage = "Failed to send invitation. Please try again.";
                Snackbar.Add("Failed to send invitation", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
            Snackbar.Add("An error occurred", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
