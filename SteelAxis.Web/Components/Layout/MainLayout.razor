@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3">SteelAxis</MudText>
        <MudSpacer />
        
        <AuthorizeView Context="appBarAuth">
            <Authorized>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudText Typo="Typo.body2">@appBarAuth.User.Identity?.Name</MudText>
                    <MudTooltip Text="Sign Out">
                        <MudIconButton Icon="@Icons.Material.Filled.Logout" 
                                       Color="Color.Inherit" 
                                       Href="/MicrosoftIdentity/Account/SignOut"
                                       aria-label="Sign out" />
                    </MudTooltip>
                </MudStack>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Inherit" 
                           Href="/MicrosoftIdentity/Account/SignIn">
                    Sign In
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">SteelAxis</MudText>
            <AuthorizeView Context="drawerAuth">
                <Authorized>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @drawerAuth.User.FindFirst("extension_TenantId")?.Value
                    </MudText>
                </Authorized>
            </AuthorizeView>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>
    
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
